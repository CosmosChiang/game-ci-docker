# Unity Multi-Platform XRDP Docker Environment Configuration
# Copy this file to .env and customize as needed

# Unity version configuration
UNITY_VERSION=2022.3.0f1
UNITY_CHANGESET=52de8fd3ce

# Image tags
TAG_SUFFIX=1.0.0

# Local development paths
PROJECT_PATH=./project
BUILD_PATH=./build
CACHE_PATH=./cache

# Docker build configuration
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Base image configuration
UBUNTU_IMAGE=ubuntu:22.04

# Platform features
INSTALL_WINE=true
INSTALL_IOS_TOOLS=true
UNITY_MODULES=android-ios-windows

# Hub and desktop settings
HUB_VERSION=3.7.0
RDP_PORT=3389

# Unity license (recommended for XRDP + Docker GUI workflow)
# Accepts raw XML content or base64-encoded XML content.
UNITY_LICENSE=

# Unity account credentials (optional fallback, not used by auto-bootstrap)
UNITY_USERNAME=
UNITY_PASSWORD=
UNITY_SERIAL=

# Docker registry (optional)
DOCKER_REGISTRY=
DOCKER_NAMESPACE=unityci
