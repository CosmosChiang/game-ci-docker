# Unity Multi-Platform Docker Environment Configuration
# Copy this file to .env and customize as needed

# Unity version configuration
UNITY_VERSION=2022.3.0f1
UNITY_CHANGESET=52de8fd3ce

# Image tags
TAG_SUFFIX=1.0.0

# Local development paths
PROJECT_PATH=./project
BUILD_PATH=./build
CACHE_PATH=./cache

# Docker build configuration
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Platform-specific configuration (uncomment to override defaults)
# ANDROID_SDK_VERSION=33
# ANDROID_NDK_VERSION=21.4.7075529
# ANDROID_BUILD_TOOLS_VERSION=33.0.2

# iOS configuration
# IOS_SDK_VERSION=16.0

# Windows configuration
# WINE_VERSION=7.0

# Build optimization
# DOCKER_BUILD_PARALLEL=true
# DOCKER_BUILD_NO_CACHE=false
